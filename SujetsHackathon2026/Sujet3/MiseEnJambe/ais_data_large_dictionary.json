{
    "description": "Fichier contenant 10 000 données AIS pour les navires de ships_large.csv.",
    "champs": {
        "mmsi": {
            "type": "String",
            "description": "MMSI du navire.",
            "exemple": "244710000",
            "format": "9 chiffres",
            "obligatoire": true
        },
        "timestamp": {
            "type": "DateTime",
            "description": "Date et heure de la donnée AIS (format ISO 8601).",
            "exemple": "2026-05-10T14:30:00Z",
            "format": "YYYY-MM-DDTHH:MM:SSZ",
            "obligatoire": true
        },
        "latitude": {
            "type": "Float",
            "description": "Latitude du navire (position AIS).",
            "exemple": 43.2965,
            "unité": "degrés décimaux",
            "plage": "-90.0 à 90.0",
            "obligatoire": true
        },
        "longitude": {
            "type": "Float",
            "description": "Longitude du navire (position AIS).",
            "exemple": -5.3698,
            "unité": "degrés décimaux",
            "plage": "-180.0 à 180.0",
            "obligatoire": true
        },
        "speed": {
            "type": "Float",
            "description": "Vitesse du navire en nœuds.",
            "exemple": 12.5,
            "unité": "nœuds",
            "plage": "0.0 - 50.0",
            "obligatoire": false
        },
        "course": {
            "type": "Float",
            "description": "Cap du navire en degrés (0-360).",
            "exemple": 270.0,
            "unité": "degrés",
            "plage": "0.0 - 360.0",
            "obligatoire": false
        },
        "status": {
            "type": "String",
            "description": "Statut de navigation du navire.",
            "exemple": "Under Way",
            "valeurs_possibles": [
                "Under Way",
                "At Anchor",
                "Moored",
                "Not under command",
                "Restricted maneuverability"
            ],
            "obligatoire": false
        },
        "ais_active": {
            "type": "Boolean",
            "description": "Indique si l'AIS du navire est activé.",
            "exemple": true,
            "valeurs_possibles": [
                true,
                false
            ],
            "obligatoire": true
        },
        "navigational_status": {
            "type": "String",
            "description": "Statut de navigation détaillé (code ITU M.1371).",
            "exemple": "0",
            "valeurs_possibles": [
                "0 (Under way using engine)",
                "1 (At anchor)",
                "2 (Not under command)",
                "3 (Restricted maneuverability)",
                "4 (Constrained by her draught)",
                "5 (Moored)",
                "6 (Aground)",
                "7 (Engaged in fishing)",
                "8 (Under way sailing)",
                "9 (Reserved for future use)",
                "10 (Reserved for future use)",
                "11 (Reserved for future use)",
                "12 (Reserved for future use)",
                "13 (Reserved for future use)",
                "14 (AIS-SART is active)",
                "15 (Not defined)"
            ],
            "obligatoire": false
        },
        "heading": {
            "type": "Float",
            "description": "Cap réel du navire en degrés (0-360).",
            "exemple": 270.0,
            "unité": "degrés",
            "plage": "0.0 - 360.0",
            "obligatoire": false
        },
        "rot": {
            "type": "Float",
            "description": "Taux de rotation (Rate of Turn) en degrés par minute.",
            "exemple": 0.0,
            "unité": "degrés/minute",
            "plage": "-127.0 à 127.0",
            "obligatoire": false
        }
    },
    "nombre_lignes": 10000,
    "fichier_associe": "ais_data_large.csv"
}