# Sujet 5 — variables d'environnement
# Copier en .env (qui est gitignored) et remplir les valeurs.
# AUCUNE de ces clés ne doit jamais être committée.

# === LLM (aligné Sujet 3) ===
LLM_BACKEND=mistral
MISTRAL_API_KEY=
MISTRAL_MODEL=mistral-small-latest        # ou mistral-large-latest pour la rédaction de fiche

# Fallbacks (optionnels)
# ANTHROPIC_API_KEY=
# OLLAMA_HOST=http://localhost:11434

# === Imagerie satellite (Piste B) ===
# Copernicus Data Space Ecosystem (gratuit, https://dataspace.copernicus.eu)
COPERNICUS_USER=
COPERNICUS_PASSWORD=
# Planet — API "classique" (api.planet.com : Data/Orders/Subscriptions/Basemaps).
#   Clé "PLAK…" depuis https://insights.planet.com/account/#/ → onglet "API Keys".
#   Auth = HTTP basic, la clé en username et mot de passe vide  (curl -u "$PLANET_API_KEY:" …).
#   Donne accès (selon le plan) à PSScene (~3 m), SkySatScene/Collect (~0,5–0,8 m, utile pour
#   classer un type de navire), REScene, etc. — quotas limités, ne pas activer de download massif.
PLANET_API_KEY=
# Sentinel Hub / Planet Insights Platform — OAuth2 client credentials (séparé de la clé PLAK).
#   Console : https://insights.planet.com/account/#/  →  panneau "OAuth Clients" (créer un client).
#   Le client_id est un UUID ; le client_secret n'est affiché qu'UNE fois à la création.
#   Token : POST https://services.sentinel-hub.com/auth/realms/main/protocol/openid-connect/token
#           (grant_type=client_credentials) → Bearer pour les API Process / Catalog / Statistical.
#   Le paquet `sentinelhub` lit ces deux variables (sh_client_id / sh_client_secret).
SENTINELHUB_CLIENT_ID=
SENTINELHUB_CLIENT_SECRET=
SENTINELHUB_INSTANCE_ID=          # (optionnel) instance OGC WMS/WCS, si tu en crées une
# Microsoft Planetary Computer : pas de clé requise (STAC public).

# === API tierces ===
# OpenWeatherMap (clé gratuite limitée, https://openweathermap.org/api) — Q15 météo de la fiche
OPENWEATHER_API_KEY=
# Global Fishing Watch (token gratuit non commercial, https://globalfishingwatch.org/our-apis/)
GFW_API_TOKEN=
# Nominatim (OSM, reverse-geocoding) & Overpass : aucune clé — politique d'usage : User-Agent + 1 req/s (géré par src/osint_enrich.py).
# Flux RSS navals (Naval News / USNI / gCaptain / Maritime Executive / Mer et Marine / Defense News) : aucune clé.

# === Telegram (OPTIONNEL — couche de corroboration, non branchée dans le livrable) ===
# Créer une application sur https://my.telegram.org → API_ID + API_HASH. Utiliser un COMPTE DÉDIÉ, jamais un numéro perso.
TELEGRAM_API_ID=
TELEGRAM_API_HASH=

# === Démo / alerte (optionnel) ===
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
ALERT_TO=
