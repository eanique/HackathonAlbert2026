# Sujet 3 — variables d'environnement
# Copier en .env (qui est gitignored) et remplir les valeurs.
# AUCUNE de ces clés ne doit jamais être committée.

# === LLM ===
# Backend principal (choix verrouillé : Mistral, souveraineté FR pour Minarm)
LLM_BACKEND=mistral
MISTRAL_API_KEY=
MISTRAL_MODEL=mistral-small-latest    # ou mistral-large-latest pour la rédaction soignée

# Fallbacks (optionnels — décommenter requirements.txt si utilisés)
# ANTHROPIC_API_KEY=
# GOOGLE_API_KEY=
# OLLAMA_HOST=http://localhost:11434

# === OSINT — sources gratuites ===
# Equasis (compte gratuit, scraping web)
EQUASIS_USERNAME=
EQUASIS_PASSWORD=

# OpenSanctions (clé API gratuite via opensanctions.org)
OPENSANCTIONS_API_KEY=

# Global Fishing Watch (token API gratuit via globalfishingwatch.org/our-apis)
GFW_API_TOKEN=

# AISStream.io (clé API gratuite — temps réel AIS via websocket)
AISSTREAM_API_KEY=

# === Démo / alerte (optionnel) ===
# Pour l'envoi d'e-mails d'alerte
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
ALERT_TO=
